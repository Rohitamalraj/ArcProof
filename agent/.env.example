# Copy to .env and fill in as needed. Every value here has a working
# fallback (mock/simulated) so the demo runs with zero keys configured.

# --- Optional: real on-chain explorer data for wallet_flow / token_concentration ---
# If unset, the on-chain agent + evaluator fall back to a deterministic
# SIMULATED explorer response (clearly labeled in claim/verification output).
ETHERSCAN_API_KEY=

# --- LLM: every agent (orchestrator, 3 specialists, evaluator) is a real
# LangChain tool-calling agent and needs a model to ask. GOOGLE_API_KEY is
# checked first -- it's free (no credit card): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Optional: separate Gemini key per agent role ---
# Google's free tier is a 20-requests/DAY cap *per key*, and every agent now
# makes real LLM calls -- five agents sharing GOOGLE_API_KEY above exhausts
# it after a couple of jobs. Generate 5 keys (aistudio.google.com/apikey,
# can be 5 different Google accounts/projects) and set one per role below;
# any role left blank falls back to the shared GOOGLE_API_KEY.
GOOGLE_API_KEY_ORCHESTRATOR=
GOOGLE_API_KEY_ONCHAIN=
GOOGLE_API_KEY_NEWS=
GOOGLE_API_KEY_COMPLIANCE=
GOOGLE_API_KEY_EVALUATOR=

# --- Optional: Circle Agent Stack (real payments) ---
# Leave unset to run entirely on the built-in mock wallet ledger
# (payments/wallet.py, payments/x402.py). See README "Going from mock
# payments to real Circle/x402/Arc" for the swap points.
CIRCLE_API_KEY=
ARC_RPC_URL=

# --- Service ports (defaults shown) ---
ORCHESTRATOR_PORT=8000
ONCHAIN_AGENT_PORT=8001
NEWS_AGENT_PORT=8002
COMPLIANCE_AGENT_PORT=8003
EVALUATOR_PORT=8004
