node_modules/
dist/
# Published SDK packages ship their compiled output (npm consumers need
# dist/, not src/) -- unignore it for those three specifically. Everything
# else (core, services, contracts, examples) runs straight off src/ via tsx
# and has no reason to commit build output.
!packages/sdk/dist/
!packages/sdk-langchain/dist/
!packages/sdk-elizaos/dist/
data/*.json
*.tsbuildinfo
