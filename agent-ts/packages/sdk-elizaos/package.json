{
  "name": "@arcproof/sdk-elizaos",
  "version": "0.2.0",
  "description": "ElizaOS plugin for @arcproof/sdk -- native orchestrator + specialist builders (runtime.useModel, no LangChain needed) plus the Action/Plugin wrapper, for a bonded, independently-verified, real-payment agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["arcproof", "elizaos", "ai-agents", "verification", "plugin"],
  "license": "MIT",
  "peerDependencies": {
    "@arcproof/sdk": "^0.1.0",
    "@elizaos/core": "^1.0.0"
  },
  "devDependencies": {
    "@arcproof/sdk": "*",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  }
}
