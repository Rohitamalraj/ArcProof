# --- Service ports (defaults shown, override only if something else is using them) ---
ORCHESTRATOR_PORT=8000
ONCHAIN_AGENT_PORT=8001
NEWS_AGENT_PORT=8002
COMPLIANCE_AGENT_PORT=8003
EVALUATOR_PORT=8004

# --- Arc testnet (public, no signup needed -- docs.arc.io/arc/references/connect-to-arc) ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EXPLORER_URL=https://testnet.arcscan.app

# --- Real per-role EVM wallets --------------------------------------------
# Generate a fresh set with: npm run gen-wallets
# (this project's wallets are intentionally independent of agent/'s -- see
# agent-ts/README.md)
REQUESTER_ADDRESS=
REQUESTER_PRIVATE_KEY=
ORCHESTRATOR_ADDRESS=
ORCHESTRATOR_PRIVATE_KEY=
ESCROW_ADDRESS=
ESCROW_PRIVATE_KEY=
ONCHAIN_AGENT_ADDRESS=
ONCHAIN_AGENT_PRIVATE_KEY=
NEWS_AGENT_ADDRESS=
NEWS_AGENT_PRIVATE_KEY=
COMPLIANCE_AGENT_ADDRESS=
COMPLIANCE_AGENT_PRIVATE_KEY=

# --- LLM provider (at least one required -- every specialist + the
# orchestrator's planner are real LangChain.js tool-calling agents) --------
# Checked first of all (see services/src/llm.ts) -- Groq's free tier has much
# more generous rate limits than Gemini's daily quota or OpenRouter's free
# model pool, with solid native tool-calling support. Get a key at
# console.groq.com/keys.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile   # default; override to any Groq model slug

# Checked second -- OpenRouter is OpenAI-API-compatible (ChatOpenAI pointed at
# a different baseURL), useful to route around Gemini's free-tier daily
# quota. Get a key at openrouter.ai/keys.
# OPENROUTER_API_KEY=
# Default model is a free-tier, tool-calling-capable OpenRouter model --
# override to any OpenRouter model slug (e.g. a paid one, if your key has
# real credit balance -- a metered model will 402 on a $0-funded free key).
# OPENROUTER_MODEL=openai/gpt-oss-120b:free

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
GOOGLE_API_KEY=
# Optional: one Gemini key per role instead of all sharing GOOGLE_API_KEY.
# Google's free tier is 20 requests/day *per key* -- 4 agents sharing one
# key exhausts it fast. Any role left unset falls back to GOOGLE_API_KEY.
# GOOGLE_API_KEY_ORCHESTRATOR=
# GOOGLE_API_KEY_ONCHAIN=
# GOOGLE_API_KEY_NEWS=
# GOOGLE_API_KEY_COMPLIANCE=

# --- Optional: upgrades wallet_flow from simulated to a live Etherscan read ---
ETHERSCAN_API_KEY=

# --- Circle Developer-Controlled Wallets (real, optional per role) --------
# See "Circle Wallets setup" in README.md. Unlike the reference Python
# version (which only ever wired the `requester` role), ANY subset of the
# 5 non-escrow roles below can be Circle-backed independently -- each one
# left blank simply falls back to its plain private key above.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID_REQUESTER=
CIRCLE_ADDRESS_REQUESTER=
CIRCLE_WALLET_ID_ORCHESTRATOR=
CIRCLE_ADDRESS_ORCHESTRATOR=
CIRCLE_WALLET_ID_ONCHAIN_AGENT=
CIRCLE_ADDRESS_ONCHAIN_AGENT=
CIRCLE_WALLET_ID_NEWS_AGENT=
CIRCLE_ADDRESS_NEWS_AGENT=
CIRCLE_WALLET_ID_COMPLIANCE_AGENT=
CIRCLE_ADDRESS_COMPLIANCE_AGENT=
